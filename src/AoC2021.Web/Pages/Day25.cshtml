@page
@model Day25Model
@{
    ViewData["Title"] = "Day 25 – Sea Cucumber";
}

<h1>Day 25 – Sea Cucumber</h1>

<div class="controls">
    <textarea id="input" rows="9" style="width:100%;max-width:700px;white-space:pre; font-family:ui-monospace,Consolas,monospace;"></textarea>
    
    <div id="dropZone" style="margin-top:8px;padding:12px;border:2px dashed #bbb;border-radius:6px;">
        Drop a .txt file here
    </div>

    <div style="margin-top:8px; display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
        <input type="file" id="fileInput" accept=".txt" />
        <button id="btnLoadFile" class="btn">Load selected file</button>
        <button id="btnLoadRepo" class="btn btn-outline-secondary">Load Day25.txt from repo</button>
        <button id="btnLoadSample" class="btn btn-outline-secondary">Load sample</button>
    </div>

    <div style="margin-top:8px;">
        <button id="btnInit" class="btn btn-primary">Initialize</button>
        <button id="btnStep" class="btn btn-secondary">Step</button>
        <button id="btnStart" class="btn btn-success">Start</button>
        <button id="btnPause" class="btn btn-warning">Pause</button>
        <span style="margin-left:12px">Speed: <input id="speed" type="range" min="50" max="800" step="50" value="200" /></span>
    </div>

    <div style="margin-top:8px;">
        <strong>Session:</strong> <span id="sid">–</span> |
        <strong>Steps:</strong> <span id="steps">0</span> |
        <strong>Status:</strong> <span id="status">idle</span>
    </div>
</div>

<div id="grid" class="grid"></div>

@section Scripts {
    <script>
        let sessionId = null;
        let timer = null;

        const elGrid  = document.getElementById('grid');
        const elSid   = document.getElementById('sid');
        const elSteps = document.getElementById('steps');
        const elStatus= document.getElementById('status');

        function render(lines) {
          const h = lines.length;
          const w = lines[0].length;
          elGrid.style.setProperty('--cols', w);
          elGrid.innerHTML = '';
          for (let r = 0; r < h; r++) {
            const row = lines[r];
            for (let c = 0; c < w; c++) {
              const ch = row[c];
              const cell = document.createElement('div');
              cell.className = 'cell ' + (ch === '>' ? 'east' : ch === 'v' ? 'south' : 'empty');
              cell.textContent = ch;
              elGrid.appendChild(cell);
            }
          }
        }

        async function init() {
          const input = document.getElementById('input').value;
          const res = await fetch('/api/day25/init', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ input })
          });
          const data = await res.json();
          sessionId = data.sessionId;
          elSid.textContent = sessionId;
          elSteps.textContent = data.steps;
          render(data.lines);
          setStatus('initialized');
        }

        async function stepOnce() {
          if (!sessionId) return;
          const res = await fetch('/api/day25/step', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ sessionId })
          });
          if (res.status === 404) { setStatus('expired'); stop(); return; }
          const data = await res.json();
          elSteps.textContent = data.steps;
          render(data.lines);
          if (!data.moved) { setStatus('stable'); stop(); }
        }

        function start() {
          if (!sessionId || timer) return;
          setStatus('running');
          const delay = () => parseInt(document.getElementById('speed').value,10);
          timer = setInterval(stepOnce, delay());
          document.getElementById('speed').addEventListener('input', () => {
            if (timer) { clearInterval(timer); timer = setInterval(stepOnce, delay()); }
          });
        }
        function stop() { if (timer) { clearInterval(timer); timer = null; } }
        function setStatus(s){ elStatus.textContent = s; }

        // ------- NEW: file upload + repo load -------
        document.getElementById('btnLoadFile').addEventListener('click', () => {
          const f = document.getElementById('fileInput').files[0];
          if (!f) { alert('Choose a .txt first'); return; }
          const reader = new FileReader();
          reader.onload = e => {
            const text = (e.target.result || '').toString()
              .replace(/\r\n/g, '\n')      // normalize newlines
              .replace(/\r/g, '\n');
            document.getElementById('input').value = text.trimEnd();
          };
          reader.readAsText(f);
        });

        document.getElementById('btnLoadRepo').addEventListener('click', async () => {
          const res = await fetch('/inputs/Day25.txt');
          const text = (await res.text()).replace(/\r\n/g, '\n').replace(/\r/g, '\n');
          document.getElementById('input').value = text.trimEnd();
        });

        const dz = document.getElementById('dropZone');
        ['dragenter','dragover','dragleave','drop'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); e.stopPropagation(); }));
        dz.addEventListener('drop', e => {
          const f = e.dataTransfer.files?.[0];
          if (!f) return;
          const reader = new FileReader();
          reader.onload = ev => {
            const text = (ev.target.result || '').toString().replace(/\r\n/g,'\n').replace(/\r/g,'\n');
            document.getElementById('input').value = text.trimEnd();
          };
          reader.readAsText(f);
        });
        // keep sample + controls
        document.getElementById('btnInit').addEventListener('click', async () => { stop(); await init(); });
        document.getElementById('btnStep').addEventListener('click', stepOnce);
        document.getElementById('btnStart').addEventListener('click', start);
        document.getElementById('btnPause').addEventListener('click', () => { setStatus('paused'); stop(); });
        document.getElementById('btnLoadSample').addEventListener('click', () => {
          document.getElementById('input').value =
        `v...>>.vv>
        .vv>>.vv..
        >>.>v>...v
        >>v>>.>.v.
        v>v.vv.v..
        >.>>..v...
        .vv..>.>v.
        v.v..>>v.v
        ....v..v.>`;
        });
    </script>
}

<style>
    .grid {
        --cols: 0;
        display: grid;
        grid-template-columns: repeat(var(--cols), 16px);
        grid-auto-rows: 16px;
        gap: 2px;
        margin-top: 12px;
        width: max-content;
        border: 1px solid #ddd;
        padding: 8px;
        background: #fafafa;
    }

    .cell {
        width: 16px;
        height: 16px;
        font: 12px/16px ui-monospace,Consolas,monospace;
        text-align: center;
        border-radius: 2px;
    }

        .cell.empty {
            color: #bbb;
        }

        .cell.east {
            color: #1e7e34;
            font-weight: 600;
        }
        /* '>' */
        .cell.south {
            color: #0d6efd;
            font-weight: 600;
        }
    /* 'v' */

    .btn {
        padding: 6px 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        cursor: pointer;
    }

        .btn:hover {
            filter: brightness(0.95);
        }

    .btn-primary {
        background: #0d6efd;
        color: white;
        border-color: #0d6efd;
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
        border-color: #6c757d;
    }

    .btn-success {
        background: #198754;
        color: white;
        border-color: #198754;
    }

    .btn-warning {
        background: #ffc107;
        color: black;
        border-color: #ffc107;
    }

    .btn-outline-secondary {
        background: white;
        color: #6c757d;
        border-color: #6c757d;
    }
</style>
